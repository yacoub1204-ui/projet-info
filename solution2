import math

def distance_point_droite(A, B, P):
    # formule de la distance d'un point P à la droite AB
    return abs((B[0] - A[0])*(A[1] - P[1]) - (A[0] - P[0])*(B[1] - A[1])) / distance(A,B)

def point_plus_proche_droite(A, B, points):
    point_le_plus_proche = points[0]
    distance_minimale = distance_point_droite(A, B, points[0])
    
    for point in points[1:]:
        d = distance_point_droite(A, B, point)
        if d < distance_minimale:
            distance_minimale = d
            point_le_plus_proche = point
    return point_le_plus_proche



def distance(point1, point2):
    return math.sqrt((point1[0] - point2[0])**2 + (point1[1] - point2[1])**2)

def pointprocheliste(points, point_ref):
    if not points:
        return None
    point_le_plus_proche = points[0]
    distance_minimale = distance(points[0], point_ref)
    for point in points[1:]:
        dist = distance(point, point_ref)
        if dist < distance_minimale:
            distance_minimale = dist
            point_le_plus_proche = point
    
    return point_le_plus_proche

def point_plus_loin(data):
    point_max = None
    distance_max = 0
    
    origine = (0, 0)
    
    for polygone in data:
        for point in polygone:
            d = distance(point, origine)
            if d > distance_max:
                distance_max = d
                point_max = point
                
    return point_max

def solution2(data):
    import copy
    plaque = copy.deepcopy(data)
    pointsolus = []
    solution = []
    for polygone in plaque:
        pointsolus.append(point_plus_proche_droite((0, 0), point_plus_loin(data), polygone))

    pointactuel = (0, 0)

    while pointsolus:  
        pointactuel = pointprocheliste(pointsolus, pointactuel)
        index_a_supprimer = pointsolus.index(pointactuel)
        polygone_choisi = plaque[index_a_supprimer]
        index_depart = polygone_choisi.index(pointactuel)
        polygone_reordonne = polygone_choisi[index_depart:] + polygone_choisi[:index_depart]
        solution.append(polygone_reordonne)
        pointactuel = polygone_reordonne[0]
        del plaque[index_a_supprimer]
        del pointsolus[index_a_supprimer]

    return solution
    
    
